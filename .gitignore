# --- Archivos de Sistema y Configuración Sensible ---
.env
/writable/*
!/writable/.gitkeep
/public/uploads/*
!/public/uploads/.gitkeep

# --- Dependencias de PHP (Composer) ---
/vendor/
/composer.lock
# Nota: Algunos prefieren subir el lock, pero en CI4 usualmente se ignora 
# si trabajas en equipos con diferentes entornos de desarrollo.

# --- Logs y Cache ---
/writable/cache/*
/writable/debugbar/*
/writable/logs/*
/writable/session/*
/writable/uploads/*
!/writable/index.html
!/writable/.gitkeep

# --- Testing ---
/tests/_support/_generated/
/tests/_output/
/tests/_envs/
.phpunit.result.cache

# --- Entornos de Desarrollo / IDEs ---
.idea/
.vscode/
*.swp
*.bak
.DS_Store
Thumbs.db

# --- Otros ---
user_guide_src/
node_modules/
npm-debug.log